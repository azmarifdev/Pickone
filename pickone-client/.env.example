# ZysLet client environment

# Backend API base
NEXT_PUBLIC_BASE_URL=http://localhost:5000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Public URLs (production)
NEXT_PUBLIC_API_URL=https://server.zyslet.com
NEXT_PUBLIC_CLIENT_URL=https://zyslet.com
NEXT_PUBLIC_ADMIN_URL=https://admin.zyslet.com

# Analytics (optional)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# WhatsApp confirmation CTA
NEXT_PUBLIC_WHATSAPP_NUMBER=8801810011145
NEXT_PUBLIC_WHATSAPP_CONFIRM_MESSAGE=Hi ZysLet, I placed an order. Order ID: {orderId}. Please confirm my order.

# Pricing rules fallback (overridden by admin DB settings)
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=0
NEXT_PUBLIC_MINIMUM_ORDER_AMOUNT=0

NODE_ENV=development
