# ZysLet root environment (Docker/local)

# Runtime
NODE_ENV=development
PORT=5000

# MongoDB container credentials
DB_NAME=zyslet-db
DB_USERNAME=zyslet-db
DB_PASSWORD=change_me
DB_HOST=mongodb
DB_PORT=27017

# MongoDB connection string
DATABASE_URL=mongodb://zyslet-db:change_me@mongodb:27017/zyslet-db?authSource=admin

# API/public URLs
NEXT_PUBLIC_BASE_URL=http://localhost:5000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
LOCAL_FILE_URL=http://localhost:5000/

# JWT
BCRYPT_SALT_ROUNDS=10
JWT_SECRET_TOKEN=change_me_super_secret
JWT_EXPIRE_IN=2d
JWT_REFRESH_TOKEN=change_me_refresh_secret
JWT_REFRESH_EXPIRE_IN=30d

# Analytics (optional)
NEXT_PUBLIC_GTM_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PIXEL_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# WhatsApp confirmation CTA
NEXT_PUBLIC_WHATSAPP_NUMBER=8801810011145
NEXT_PUBLIC_WHATSAPP_CONFIRM_MESSAGE=Hi ZysLet, I placed an order. Order ID: {orderId}. Please confirm my order.
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=0
NEXT_PUBLIC_MINIMUM_ORDER_AMOUNT=0
