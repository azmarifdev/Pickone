# ZysLet backend environment
NODE_ENV=development
PORT=5000
LOCAL_FILE_URL=http://localhost:5000/

# Public URLs
API_URL=https://server.zyslet.com
CLIENT_URL=https://zyslet.com
ADMIN_URL=https://admin.zyslet.com

# Database
DATABASE_URL=mongodb://zyslet-db:change_me@localhost:27017/zyslet-db?authSource=admin

# Auth
BCRYPT_SALT_ROUNDS=10
JWT_SECRET_TOKEN=change_me_super_secret
JWT_EXPIRE_IN=2d
JWT_REFRESH_TOKEN=change_me_refresh_secret
JWT_REFRESH_EXPIRE_IN=30d

# Uploads
FILE_UPLOAD_PATH=/app/server-tmp
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,webp

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:4000,https://zyslet.com,https://admin.zyslet.com

# Optional Meta Conversion API
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PIXEL_ID=
